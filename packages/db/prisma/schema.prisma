generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String    @id @default(uuid())
  email    String    @unique
  password String
  websites Website[]
}

model Website {
  id        String        @id @default(uuid())
  url       String
  timeAdded DateTime
  user_id   String
  user      User          @relation(fields: [user_id], references: [id])
  ticks     WebsiteTick[]
}

model Region {
  id    String        @id @default(uuid())
  name  String
  ticks WebsiteTick[]
}

model WebsiteTick {
  id               String        @id @default(uuid())
  response_time_ms Int
  status           WebsiteStatus
  region_id        String
  website_id       String
  createdAt        DateTime      @default(now())
  region           Region        @relation(fields: [region_id], references: [id])
  website          Website       @relation(fields: [website_id], references: [id])
}

enum WebsiteStatus {
  Up
  Down
  Unknown
}
